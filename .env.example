# DeepSeek 在线模型配置
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 视觉模型配置，用于图片理解
VISION_API_KEY=your-vision-api-key
VISION_BASE_URL=https://ai.devtool.tech/proxy/v1
VISION_MODEL=gpt-4o

# GraphRAG 的嵌入模型配置
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_API_BASE=https://ai.devtool.tech/proxy/v1
EMBEDDING_MODEL_NAME=text-embedding-3-small

# 通过 Ollama 本地部署的模型
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:32b
OLLAMA_REASON_MODEL=deepseek-r1:32b
OLLAMA_AGENT_MODEL=qwen2.5:32b
OLLAMA_EMBEDDING_MODEL=bge-m3

# 模型服务选择
CHAT_SERVICE=deepseek
REASON_SERVICE=ollama
AGENT_SERVICE=deepseek

# 联网搜索配置
SERPAPI_KEY=your-serpapi-key
SEARCH_RESULT_COUNT=10

# MySQL 配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-db-password
DB_NAME=customer_service

# Neo4j 配置
NEO4J_URL=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# JWT 配置
SECRET_KEY=replace-with-a-long-random-secret

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_EXPIRE=3600
REDIS_CACHE_THRESHOLD=0.90

# GraphRAG 配置
GRAPHRAG_PROJECT_DIR=llm_backend/app/graphrag
GRAPHRAG_DATA_DIR=data
GRAPHRAG_QUERY_TYPE=local
GRAPHRAG_RESPONSE_TYPE=text
GRAPHRAG_COMMUNITY_LEVEL=3
GRAPHRAG_DYNAMIC_COMMUNITY=false
